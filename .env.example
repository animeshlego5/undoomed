# =============================================================================
# Un-doomed backend configuration — copy this file to ".env" and fill it in.
#
# NOTE: This .env is only a FALLBACK. The normal way to choose a provider and
# enter a key is the extension's Settings (⚙) page, which sends them per request.
# You only need this file when running the backend WITHOUT the extension
# (e.g. smoke_test.py or hitting /api/review directly).
#
# The .env file lives in this folder (next to server.py) and is loaded
# automatically on startup. NEVER commit your real .env (it holds secrets).
# =============================================================================

# --- 1. Choose your AI provider ----------------------------------------------
# One of: openai | anthropic | gemini | deepseek   (default: openai)
LLM_PROVIDER=openai

# --- 2. (Optional) Override the model for that provider ----------------------
# Leave blank to use the sensible default for the chosen provider:
#   openai    -> gpt-4o-mini
#   anthropic -> claude-opus-4-8
#   gemini    -> gemini-2.0-flash
#   deepseek  -> deepseek-chat
# LLM_MODEL=

# --- 3. Set the API key for whichever provider you chose ---------------------
# You only need the key that matches LLM_PROVIDER above.
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# DEEPSEEK_API_KEY=...

# --- 4. (Optional) Lock down the API with a shared secret --------------------
# If set, every /api/review request must send a matching `X-Server-Secret`
# header (clients add it from their Settings / config). Leave UNSET for open,
# frictionless local development. Strongly recommended for a public backend.
# UNDOOMED_SERVER_SECRET=choose-a-long-random-string

# --- 5. (Optional) Persistent DB path for cloud disks ------------------------
# UNDOOMED_DB=/data/undoomed_state.db
