# Keep the Python backend OUT of the Vercel deploy entirely, so Vercel never
# tries to build it. Vercel builds ONLY website/ (see vercel.json); the
# extension source files stay in the upload because the website build zips
# them into the downloadable undoomed-extension.zip.

# --- Python backend & packaging ---
# (anchored to the repo root so it does NOT match website/src/)
/src/
*.py
pyproject.toml
requirements.txt
*.egg-info/
__pycache__/

# --- Local data / secrets ---
.env
.env.example
undoomed_state.db
undoomed_state.db-shm
undoomed_state.db-wal

# --- Backend container files ---
Dockerfile
.dockerignore

# --- Website build artifacts (rebuilt on Vercel) ---
website/node_modules/
website/dist/
website/public/undoomed-extension.zip
