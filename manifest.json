{
  "manifest_version": 3,
  "name": "Un-doomed — Socratic Reviewer",
  "version": "1.5.1",
  "description": "Get Socratic hints (never the answer) on your LeetCode solution, then a style review once the logic is clean. Talks to your local Un-doomed API.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://127.0.0.1:8000/*",
    "https://*.onrender.com/*",
    "https://*.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Un-doomed Socratic Review",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["md.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
